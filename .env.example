# ── Twilio (WhatsApp + Calling) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── AI providers ───────────────────────────────────────────────────────────────
# OpenRouter (used by WhatsApp + Telegram channels)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Gemini (used by the calling voice agent)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_ACCESS_TOKEN=   # optional; leave blank if using API key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Kore

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=XXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Calling agent (public URL for Twilio webhooks) ────────────────────────────
BASE_URL=https://your-ngrok-url.ngrok.io

# ── NL-to-SQL ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# ── V1 Public API ─────────────────────────────────────────────────────────────
V1_API_KEY=    # leave blank to disable auth in dev mode
V1_PLAN_TIER=pro   # free | basic | pro | enterprise

# ── Server ─────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8000
API_PORT=8001
